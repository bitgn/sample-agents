# pac1-py secrets — не коммитить в git
#
# Приоритет провайдеров:
#   1. ANTHROPIC_API_KEY   — Anthropic SDK напрямую (предпочтительно для Claude)
#   2. OPENROUTER_API_KEY  — OpenRouter fallback (если нет Anthropic ключа)
#   3. Ничего              — только Ollama (локальные модели)

# ─── Anthropic (console.anthropic.com/settings/api-keys) ───────────────────
# ANTHROPIC_API_KEY=sk-ant-...

# ─── OpenRouter (openrouter.ai/settings/keys) ──────────────────────────────
# OPENROUTER_API_KEY=sk-or-...
# ─── Ollama (локально, опционально) ─────────────────────────────────────────
# По умолчанию: http://localhost:11434/v1
# OLLAMA_BASE_URL=http://localhost:11434/v1
# Модель по умолчанию (если нет ollama_model в MODEL_CONFIGS): qwen2.5:7b
# OLLAMA_MODEL=qwen2.5:7b

# ─── Benchmark runner (опциональные переопределения) ────────────────────────
# BENCHMARK_HOST=https://api.bitgn.com
# BENCHMARK_ID=bitgn/pac1-dev
# MODEL_ID=anthropic/claude-haiku-4.5
