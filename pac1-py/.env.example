# pac1-py/.env.example — модели по типам задач (без credentials)
# Скопируй в .env и настрой нужные модели.
# Credentials (API-ключи) хранятся отдельно в .secrets
#
# Типы задач:
#   default     — стандартные операции (capture/read/write одного файла)
#   think       — аналитика: distill, analyze, summarize
#   tool        — batch-операции: delete many, move, rename нескольких файлов
#   longContext — задачи с длинным контекстом: много файлов, большие документы
#
# Если переменная не задана — используется MODEL_ID (одна модель для всего)

# MODEL_DEFAULT=anthropic/claude-haiku-4.5
# MODEL_THINK=anthropic/claude-sonnet-4.6
# MODEL_TOOL=anthropic/claude-haiku-4.5
# MODEL_LONG_CONTEXT=anthropic/claude-sonnet-4.6
